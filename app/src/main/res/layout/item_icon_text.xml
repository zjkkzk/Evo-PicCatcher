<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivItemIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="12dp"
            app:tint="?attr/colorPrimary"
            tools:src="@drawable/ic_icon_check" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="模块已激活" />

            <!-- 新增：Pic Catcher Evo Edition -->
            <TextView
                android:id="@+id/tvItemEvoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pic Catcher Evo Edition"
                android:textStyle="bold"
                android:textSize="17sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvItemTitleSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                tools:text="模块版本：v1.2.3-evo" />

            <TextView
                android:id="@+id/tvItemTitleSub2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textSize="12sp"
                tools:text="代码分支: main" />

            <!-- Sub3 (提交哈希) 已被逻辑隐藏 -->
            <TextView
                android:id="@+id/tvItemTitleSub3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvItemTitleSub4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textSize="12sp"
                tools:text="构建时间: 2023/02/17" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>